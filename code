app = Flask(__name__)
app.secret_key = "eventsecret"

events = []
additional_forms = []

users = {
    "lavanya@gmail.com": {"name": "Lavanya", "password": "1234"},
    "user@gmail.com": {"name": "User", "password": "1111"}
}

admin = {"email": "admin@gmail.com", "password": "admin123"}

